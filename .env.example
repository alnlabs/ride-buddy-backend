DB_HOST=localhost
DB_PORT=5433
DB_NAME=ridebuddy
DB_USER=ridebuddy
DB_PASSWORD=ridebuddy
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits
APP_AUTH_MOCK_OTP=true
APP_CORS_ORIGINS=*
SERVER_PORT=8080
# Public share landing pages (served by this API at /r/{id} and /n/{id})
APP_SHARE_RIDE_BASE_URL=http://127.0.0.1:8080/r
APP_SHARE_NEED_BASE_URL=http://127.0.0.1:8080/n
APP_SHARE_APP_STORE_URL=https://ridebuddy.alnlabs.com
APP_SHARE_PLAY_STORE_URL=https://ridebuddy.alnlabs.com

# Google Maps Platform — live-traffic driving routes (Routes API)
# Use a SERVER key (API restriction: Routes API). Do NOT use an Android-app-only key.
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=
